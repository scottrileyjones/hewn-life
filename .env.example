# Stripe — server-side secret (never expose to client)
STRIPE_SECRET_KEY=sk_live_...

# Stripe — client-side publishable key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe — subscription plan Price IDs
NEXT_PUBLIC_STRIPE_PRICE_HEWN_MONTHLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_HEWN_ANNUAL=price_...
NEXT_PUBLIC_STRIPE_PRICE_WROUGHT_MONTHLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_WROUGHT_ANNUAL=price_...
NEXT_PUBLIC_STRIPE_PRICE_FORGED_MONTHLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_FORGED_ANNUAL=price_...

# Stripe — Website in a Week (one-time $1,000)
NEXT_PUBLIC_STRIPE_PRICE_WEBSITE_IN_A_WEEK=price_1TdMVHIQRRcdxnwWOqJLBQek

# Stripe — à la carte service Price IDs
NEXT_PUBLIC_STRIPE_PRICE_SERVICE_EXTRA_AD_CREATIVE=price_...
NEXT_PUBLIC_STRIPE_PRICE_SERVICE_EMAIL_AUTOMATION=price_...
NEXT_PUBLIC_STRIPE_PRICE_SERVICE_SEO_BLOG_POST=price_...
NEXT_PUBLIC_STRIPE_PRICE_SERVICE_VIDEO_REPURPOSING=price_...
NEXT_PUBLIC_STRIPE_PRICE_SERVICE_WHITEPAPER=price_...
NEXT_PUBLIC_STRIPE_PRICE_SERVICE_COMPETITOR_AUDIT=price_...
NEXT_PUBLIC_STRIPE_PRICE_SERVICE_BRAND_REFRESH=price_...
NEXT_PUBLIC_STRIPE_PRICE_SERVICE_WEBSITE_COPY=price_...

# Airtable — quiz lead capture
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_TABLE_ID=tblXXXXXXXXXXXXXX
AIRTABLE_TOKEN=patXXXXXXXXXXXXXX

# Google Tag Manager — container ID (configure GA4 + other tags inside GTM).
# Leave unset to disable all analytics loading (e.g. local dev).
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
